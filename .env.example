# Salin ke .env lokal — jangan komit berkas .env.

# Postgres (Neon, Render, dll.) — ganti USER, PASSWORD, HOST, DBNAME
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require"

# Opsional: set 1 untuk set_config tenant per transaksi (lihat src/server/tenant-db-context.ts + migrasi tenant_rls).
# Produksi ketat: buat role DB non-owner + FORCE ROW LEVEL SECURITY pada tabel tenant.
# Set 1 setelah migrasi tenant_rls — mengaktifkan set_config per transaksi di jalur nilai/rekap/SKL.
DATABASE_TENANT_RLS="1"

# Auth.js / NextAuth
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Daftar email superadmin (koma pisah); huruf besar/kecil diabaikan
SUPERADMIN_EMAILS="you@example.com"

# Email notifikasi (Resend) — https://resend.com
RESEND_API_KEY=""
RESEND_FROM="Sistem Nilai Ijazah <noreply@domain-verified.com>"

# Cloudinary (kop surat / aset cetak) — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Google Drive — baca folder SKL siswa (service account, hanya daftar berkas PDF; tidak memakai Cloudinary)
# Buat service account di Google Cloud Console, aktifkan API "Google Drive", unduh JSON kunci.
# GOOGLE_DRIVE_SKL_PRIVATE_KEY: isi satu baris dengan \n untuk ganti baris (seperti di JSON yang di-escape).
GOOGLE_DRIVE_SKL_CLIENT_EMAIL=""
GOOGLE_DRIVE_SKL_PRIVATE_KEY=""

# --- Render.com ---
# Set env vars yang sama di dashboard Render. NEXTAUTH_URL = URL publik service (HTTPS).
# buildCommand direkomendasikan: npm install && npx prisma migrate deploy && npm run build
